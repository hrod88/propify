{
  "expo": {
    "name": "Propify",
    "slug": "propify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f2341"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.propify.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f2341"
      },
      "package": "com.propify.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "propify",
    "plugins": [
      "expo-router"
    ]
  }
}
